# OpenCode Wrapper - Environment Variables

# =============================================================================
# Required Variables
# =============================================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/opencode"

# Clerk Authentication (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Encryption Key - Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-character-hex-key-here"

# =============================================================================
# Optional Variables
# =============================================================================

# App URL (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# GitHub OAuth (optional, for Git integration)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitLab OAuth (optional, for Git integration)
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""

# Docker Socket Path (for CLI execution)
DOCKER_SOCKET="/var/run/docker.sock"

# Workspace Base Directory (where execution workspaces are created)
# Local development: defaults to ./.workspace (relative to project root)
# Production (Railway/Coolify): set to /workspace for persistent volume
WORKSPACE_BASE=""

# Docker mode (set to "true" for containerized execution)
USE_DOCKER="false"
